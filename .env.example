# Server Configuration
SERVER_URL=https://your-domain.com
PORT=8080

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (backend only, never expose)
SUPABASE_ANON_KEY=eyJ...     # anon key (for auth operations)
SUPABASE_JWT_SECRET=your-jwt-secret

# Instructions:
# 1. Create a Supabase project at https://supabase.com
# 2. Run database/schema.sql in the SQL Editor
# 3. Get SUPABASE_URL from Project Settings > API
# 4. Get SUPABASE_SERVICE_KEY from Project Settings > API (service_role secret)
# 5. Get SUPABASE_ANON_KEY from Project Settings > API (anon public)
# 6. Get SUPABASE_JWT_SECRET from Project Settings > API > JWT Settings
